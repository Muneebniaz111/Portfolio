# ── Email Configuration ──────────────────────────────────────────────────────
# Email address to send emails from (Gmail account with 2FA enabled)
EMAIL_USER=your-email@gmail.com

# Encrypted email password (use encryption utility to generate)
# Format: <iv_hex>:<authTag_hex>:<ciphertext_hex>
EMAIL_PASSWORD_ENCRYPTED=your-encrypted-password-here

# Encryption key (hex format, 64 characters = 256 bits)
ENCRYPTION_KEY=your-encryption-key-hex-here

# Email address where contact form messages are sent
RECIPIENT_EMAIL=recipient@gmail.com
