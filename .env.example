# ── Email Configuration ────────────────────────────────────────────────────────
# Required for the contact form and OTP-based resume upload feature.
# Add these in Vercel Dashboard → Project → Settings → Environment Variables

# Your Gmail address used to send emails
EMAIL_USER=your-email@gmail.com

# AES-256-GCM encrypted Gmail App Password
# Format: <iv_hex>:<authTag_hex>:<ciphertext_hex>
# Generate with: node -e "
#   const {createCipheriv,randomBytes}=require('crypto');
#   const key=randomBytes(32); const iv=randomBytes(12);
#   const c=createCipheriv('aes-256-gcm',key,iv);
#   let enc=c.update('YOUR_APP_PASSWORD','utf8','hex')+c.final('hex');
#   console.log('ENCRYPTION_KEY='+key.toString('hex'));
#   console.log('EMAIL_PASSWORD_ENCRYPTED='+iv.toString('hex')+':'+c.getAuthTag().toString('hex')+':'+enc);
# "
EMAIL_PASSWORD_ENCRYPTED=iv_hex:authTag_hex:ciphertext_hex

# The 32-byte hex key used to encrypt/decrypt EMAIL_PASSWORD_ENCRYPTED
ENCRYPTION_KEY=your_64_char_hex_key

# Email address that receives contact form submissions and OTP codes
RECIPIENT_EMAIL=your-email@gmail.com

# Anthropic API key used by the resume tailor proxy route
ANTHROPIC_API_KEY=your_anthropic_api_key
